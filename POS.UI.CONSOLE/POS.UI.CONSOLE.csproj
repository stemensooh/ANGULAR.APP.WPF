  </ItemGroup>
  
  <ItemGroup>
    <ProjectReference Include="..\POS.APPLICATION\POS.APPLICATION.csproj" />
  </ItemGroup>
  
  <ItemGroup>
    <None Update="appsettings.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
